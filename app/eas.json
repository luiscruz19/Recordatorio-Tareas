{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview-test": {
      "distribution": "internal",
      "channel": "preview-test",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://recordatorios.sda.ovh"
      }
    },
    "preview-local": {
      "distribution": "internal",
      "channel": "preview-local",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.100.8:4010"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": { "buildType": "app-bundle" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://recordatorios.sda.ovh"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
