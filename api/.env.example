# ─── Servidor ──────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=80

# ─── Base de datos (MySQL compartido de /opt/shared, en net-shared) ─────────
DB_HOST=mysql_db
DB_PORT=3306
DB_USER=root
# Lo completa `make env` leyendo /opt/shared/.env (no se commitea el secreto).
DB_ROOT_PASSWORD=CHANGEME
DB_NAME=RECORDATORIOS
DB_DIALECT=mysql

# ─── JWT (DEBE ser la misma SECRET_KEY que fichada → mismos usuarios) ───────
SECRET_KEY=supersecret

# ─── Servicios core: se REUSAN los de fichada (corriendo en net-shared) ─────
AUTH_API_URL=http://fichada_auth
MAILER_API_URL=http://fichada_mailer

# Basic Auth servicio↔servicio (los mismos que fichada, para hablar con auth/mailer)
AUTH_BASIC_USER=auth
AUTH_BASIC_PW=secret
MAILER_BASIC_USER=mailer
MAILER_BASIC_PW=secret

# ─── Jobs ────────────────────────────────────────────────────────────────────
# Apagar el cron de recordatorios con ENABLE_JOBS=false (p.ej. en tests).
ENABLE_JOBS=true
# Tick del scheduler (no es el intervalo del usuario; ese vive en sus ajustes).
TASK_REMINDER_CRON=*/15 * * * *

# ─── Frontend ──────────────────────────────────────────────────────────────
WEB_URL=http://localhost:8081
