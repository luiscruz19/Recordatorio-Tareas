# Runtime del server de test. Copiar como `.env` en /opt/test/recordatorios (NO se versiona).
#
# ⚠ IMPORTANTE: SECRET_KEY y AUTH_BASIC_*/MAILER_BASIC_* deben ser EXACTAMENTE los mismos
#   que el .env de /opt/test/fichada. Es lo que permite "mismos usuarios que fichada":
#   el JWT que emite fichada_auth se valida acá con la misma SECRET_KEY.

NODE_ENV=production
API_PORT=80

# ─── Base de datos (MySQL compartido de /opt/shared, red net-shared) ─────────
DB_HOST=mysql_db
DB_PORT=3306
DB_USER=root
DB_ROOT_PASSWORD=__PASSWORD_DEL_MYSQL_COMPARTIDO__
DB_NAME=RECORDATORIOS
DB_DIALECT=mysql

# ─── JWT + Basic Auth servicio↔servicio (LOS MISMOS QUE FICHADA) ─────────────
SECRET_KEY=__EL_MISMO_SECRET_QUE_FICHADA__
AUTH_BASIC_USER=auth
AUTH_BASIC_PW=__EL_MISMO_BASIC_PW_QUE_FICHADA__
MAILER_BASIC_USER=mailer
MAILER_BASIC_PW=__EL_MISMO_BASIC_PW_QUE_FICHADA__

# ─── Servicios core de fichada (hostnames de net-shared) ─────────────────────
AUTH_API_URL=http://fichada_auth
MAILER_API_URL=http://fichada_mailer
# El login (incluido el PIN) se delega a la api de fichada.
FICHADA_API_URL=http://fichada_api

# ─── Jobs (cron de recordatorios) ────────────────────────────────────────────
ENABLE_JOBS=true
TASK_REMINDER_CRON=*/15 * * * *

WEB_URL=https://recordatorios.sda.ovh
